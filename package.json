{
  "name": "maven-auto-scaffold",
  "displayName": "Maven Auto Scaffold",
  "description": "Automatically creates Maven directory structure when a pom.xml is added",
  "version": "1.0.6",
  "publisher": "snupai",
  "repository": {
    "type": "git",
    "url": "https://github.com/Snupai/maven-auto-scaffold.git"
  },
  "homepage": "https://github.com/Snupai/maven-auto-scaffold#readme",
  "bugs": {
    "url": "https://github.com/Snupai/maven-auto-scaffold/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/pom.xml",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
